# Copy to .env — never commit .env to git.

# Local dev (default): SQLite file in backend/
DATABASE_URL=sqlite:///fabrics.db

# Production: PostgreSQL
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/fabrics

# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

ADMIN_USERNAME=Pratham
ADMIN_PASSWORD=your-new-strong-password-here

FLASK_DEBUG=1
